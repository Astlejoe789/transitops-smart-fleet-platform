# ==========================================
# TransitOps Environment Variables Template
# ==========================================

# --- General ---
NODE_ENV=development
PORT=3000

# --- Database (PostgreSQL) ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/transitops?schema=public

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=transitops

# --- Security & Authentication ---
# Generate a secure random string for production (e.g. `openssl rand -hex 32`)
JWT_SECRET=supersecretjwtkeyforlocaldevonly
JWT_EXPIRES_IN=24h

# --- Frontend (apps/web) ---
# Base URL for the backend API
VITE_API_URL=http://localhost:3000/api

# --- AI Integration (Optional) ---
# Replace with actual keys if enabling cloud AI providers
OPENAI_API_KEY=sk-your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key

# --- Notifications (Optional) ---
# SMTP Configuration for email alerts
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@transitops.com
